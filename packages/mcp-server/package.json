{
	"name": "@sei-js/mcp-server",
	"description": "Model Context Protocol (MCP) server for interacting with EVM-compatible networks",
	"type": "module",
	"version": "0.3.2",
	"bin": "./bin/mcp-server.js",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist/", "bin/", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsc -b",
		"dev": "tsx watch src/index.ts",
		"clean": "rm -rf dist",
		"start": "node dist/index.js",
		"start:http": "node dist/index.js --streamable-http",
		"start:http-sse": "node dist/index.js --http-sse",
		"inspect": "npx -y @modelcontextprotocol/inspector",
		"test": "bun test",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"tsx": "^4.20.3"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.7.0",
		"@noble/hashes": "^1.8.0",
		"commander": "^14.0.0",
		"cors": "^2.8.5",
		"dotenv": "^16.5.0",
		"express": "^4.21.2",
		"trieve-ts-sdk": "^0.0.121",
		"viem": "^2.30.5",
		"zod": "^3.24.2"
	},
	"keywords": ["mcp", "model-context-protocol", "evm", "blockchain", "sei", "web3", "smart-contracts", "ai", "agent"],
	"author": "@codebycarson",
	"license": "MIT",
	"engines": {
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sei-protocol/sei-js.git",
		"directory": "packages/mcp-server"
	},
	"bugs": {
		"url": "https://github.com/sei-protocol/sei-js/issues"
	},
	"homepage": "https://github.com/sei-protocol/sei-js/tree/main/packages/mcp-server#readme",
	"publishConfig": {
		"access": "public"
	}
}
